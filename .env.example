# notebook-mcp shared defaults

NOTEBOOK_MCP_DATA_DIR=.local/notebook-mcp
NOTEBOOK_MCP_DB_PATH=.local/notebook-mcp/db/notebook_mcp.sqlite3
NOTEBOOK_MCP_LOG_LEVEL=INFO
NOTEBOOK_MCP_HOST=127.0.0.1
NOTEBOOK_MCP_PORT=8000
NOTEBOOK_MCP_TRANSPORT=streamable-http
NOTEBOOK_MCP_EMBEDDING_BACKEND=local
NOTEBOOK_MCP_EMBEDDING_MODEL=
NOTEBOOK_MCP_BROWSER_PROFILE_DIR=.local/notebook-mcp/auth/browser-profile
